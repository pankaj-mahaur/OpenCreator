# ── LLM ────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Voice ──────────────────────────────────────────────────
VOICE_MODEL_TYPE=edge
EDGE_TTS_VOICE=en-US-ChristopherNeural

# ── Video Generation (FAL.ai) ─────────────────────────────
FAL_API_KEY=your_fal_api_key_here
VIDEO_GEN_MODEL=kling-1.6
AVATAR_PHOTO_PATH=assets/my_photo.png

# ── B-Roll ─────────────────────────────────────────────────
# PEXELS_API_KEY=your_pexels_key

# ── Instagram (for future use) ────────────────────────────
# IG_USERNAME=
# IG_PASSWORD=

# ── Web UI ─────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8501
