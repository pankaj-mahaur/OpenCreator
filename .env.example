# ── LLM ────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Voice ──────────────────────────────────────────────────
# Set to true to enable local Qwen3-TTS voice cloning (requires CUDA GPU)
VOICE_CLONING=false
# Edge TTS fallback voice (used when VOICE_CLONING=false)
EDGE_TTS_VOICE=en-US-ChristopherNeural

# ── Qwen3 TTS (local voice cloning) ───────────────────────
# HuggingFace model ID — downloaded automatically on first run (~3.5 GB)
# QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
# Use "cpu" if you don't have a CUDA GPU (much slower)
# QWEN_TTS_DEVICE=cuda:0
# Transcript of your voice_samples/my_voice.wav reference audio
# Improves clone quality. Leave blank to use x-vector mode (no transcript).
# VOICE_CLONE_REF_TEXT=Your exact words spoken in my_voice.wav go here

# ── Video Generation ───────────────────────────────────────
# Provider: "liveportrait" (local GPU, free), "google" (Veo 3.1), or "kling"
VIDEO_GEN_PROVIDER=liveportrait
AVATAR_PHOTO_PATH=assets/my_photo.png

# Google Veo 3.1 (primary cloud provider)
# Get your key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=AIzaSy...

# Kling AI (cloud fallback via direct API)
# KLING_ACCESS_KEY=ATk9r...
# KLING_SECRET_KEY=QCp4B...

# Legacy — FAL.ai (deprecated, no longer used)
# FAL_API_KEY=your_fal_api_key_here

# ── B-Roll ─────────────────────────────────────────────────
# PEXELS_API_KEY=your_pexels_key

# ── Instagram (for future use) ────────────────────────────
# IG_USERNAME=
# IG_PASSWORD=

# ── Web UI ─────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8501
